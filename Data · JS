// ===== DRAPE DATA LAYER =====
// All data stored in localStorage so it persists across page visits.

const DB = {
  // --- Products ---
  getProducts() {
    try {
      const raw = localStorage.getItem('drape_products');
      return raw ? JSON.parse(raw) : this._seedProducts();
    } catch { return []; }
  },
  saveProducts(products) {
    localStorage.setItem('drape_products', JSON.stringify(products));
  },
  addProduct(product) {
    const products = this.getProducts();
    product.id = 'p_' + Date.now() + '_' + Math.random().toString(36).slice(2, 6);
    product.createdAt = Date.now();
    products.push(product);
    this.saveProducts(products);
    return product;
  },
  updateProduct(id, data) {
    const products = this.getProducts();
    const idx = products.findIndex(p => p.id === id);
    if (idx !== -1) {
      products[idx] = { ...products[idx], ...data };
      this.saveProducts(products);
      return products[idx];
    }
    return null;
  },
  deleteProduct(id) {
    const products = this.getProducts().filter(p => p.id !== id);
    this.saveProducts(products);
  },

  // --- Orders ---
  getOrders() {
    try {
      const raw = localStorage.getItem('drape_orders');
      return raw ? JSON.parse(raw) : [];
    } catch { return []; }
  },
  saveOrder(order) {
    const orders = this.getOrders();
    order.id = 'ORD-' + Date.now().toString().slice(-6);
    order.createdAt = Date.now();
    orders.push(order);
    localStorage.setItem('drape_orders', JSON.stringify(orders));
    return order;
  },
  clearOrders() {
    localStorage.removeItem('drape_orders');
  },

  // --- Cart ---
  getCart() {
    try {
      const raw = localStorage.getItem('drape_cart');
      return raw ? JSON.parse(raw) : [];
    } catch { return []; }
  },
  saveCart(cart) {
    localStorage.setItem('drape_cart', JSON.stringify(cart));
  },
  clearCart() {
    localStorage.removeItem('drape_cart');
  },

  // --- Seed data (shown when store is brand new) ---
